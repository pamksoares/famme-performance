{
  "expo": {
    "name": "Femme Performance",
    "slug": "femme-performance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "femme",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a08"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.famme.performance",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "O Femme Performance lê seus dados de sono, HRV e frequência cardíaca para calcular seu score diário.",
        "NSHealthUpdateUsageDescription": "O Femme Performance não escreve dados no Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a08"
      },
      "package": "app.famme.performance",
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#c8f09a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f12f9c7c-7323-445e-9c14-d9e4fc7b1d7f"
      }
    }
  }
}
